{
  "name": "@energy8platform/game-engine-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for @energy8platform/platform-core and @energy8platform/game-engine",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace @energy8platform/game-engine",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"packages/*/src/**/*.ts\"",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:watch": "npm run test:watch --workspace @energy8platform/game-engine"
  },
  "devDependencies": {
    "prettier": "^3.4.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/energy8platform/game-engine.git"
  }
}
